{
  "name": "cordn-browser",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.17.1",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "lint": "eslint .",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "check:upstream": "scripts/check-cordn-upstream-parity.sh",
    "ci": "pnpm lint && pnpm test && pnpm build && pnpm test:e2e"
  },
  "dependencies": {
    "@contextvm/mcp-sdk": "1.29.1",
    "@contextvm/sdk": "0.12.0",
    "@noble/ciphers": "2.2.0",
    "@noble/secp256k1": "3.1.0",
    "nostr-tools": "2.23.5",
    "svelte": "5.56.3",
    "ts-mls": "2.0.0-rc.12",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@playwright/test": "1.61.0",
    "@sveltejs/vite-plugin-svelte": "7.1.2",
    "@tailwindcss/vite": "4.3.1",
    "@types/node": "25.6.2",
    "@types/ws": "8.18.1",
    "eslint": "10.5.0",
    "eslint-plugin-svelte": "3.19.0",
    "globals": "17.6.0",
    "jsdom": "29.1.1",
    "svelte-eslint-parser": "1.8.0",
    "tailwindcss": "4.3.1",
    "typescript": "5.9.3",
    "typescript-eslint": "8.61.1",
    "vite": "8.0.16",
    "vitest": "4.1.9",
    "ws": "8.18.3"
  }
}
